# Default environment for Hestia
# Copy to /etc/hestia/ and customize

HUB_DOMAIN=localhost
HUB_API_GATEWAY_PORT=8000
HUB_FILE_PROCESSOR_PORT=8001
HUB_STORAGE_SERVICE_PORT=8002
HUB_IOT_BRIDGE_PORT=8003
HUB_JOB_QUEUE_PORT=8004
HUB_REDIS_URL=redis://localhost:6379/0
HUB_LOG_LEVEL=INFO
HUB_ENABLE_NEXTCLOUD=false
HUB_ENABLE_NFS=false
HUB_ENABLE_ZFS=false
HUB_ENABLE_TAILSCALE=false
