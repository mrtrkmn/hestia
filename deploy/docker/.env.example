# Hestia — Docker Compose Environment
# Copy to .env and customize

HUB_DOMAIN=localhost
HUB_SECRET_KEY=change-me-in-production
HUB_REDIS_URL=redis://redis:6379/0
HUB_API_GATEWAY_PORT=8000
HUB_FILE_PROCESSOR_PORT=8001
HUB_STORAGE_SERVICE_PORT=8002
HUB_IOT_BRIDGE_PORT=8003
HUB_JOB_QUEUE_PORT=8004
HUB_LOG_LEVEL=INFO
